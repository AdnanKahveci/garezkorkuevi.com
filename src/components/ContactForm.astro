---
import { WHATSAPP_NUMBER } from '@/config/contact';
import { EXPERIENCE } from '@/config/site';

const timeOptions = ['18:00', '19:00', '20:00', '21:00', '22:00', '23:00'];
---

<form class="reservation-form" id="HomeFormReservation" data-safe-zone="form" data-whatsapp={WHATSAPP_NUMBER}>
  <div class="reservation-form__header">
    <p class="reservation-form__title">Randevu talebi</p>
    <p class="reservation-form__channel"><span aria-hidden="true"></span> WhatsApp üzerinden</p>
  </div>

  <div class="reservation-form__grid">
    <label class="reservation-form__field reservation-form__field--name">
      <span>Adın</span>
      <input type="text" id="res-name" name="name" placeholder="Nasıl hitap edelim?" autocomplete="name" maxlength="60" />
    </label>

    <label class="reservation-form__field">
      <span>Ekip</span>
      <select id="res-guests" name="guests" required>
        <option value="" disabled selected>Kişi sayısı</option>
        {Array.from({ length: EXPERIENCE.maxGuests - EXPERIENCE.minGuests + 1 }, (_, index) => index + EXPERIENCE.minGuests).map((number) => (
          <option value={String(number)}>{number} kişi</option>
        ))}
      </select>
    </label>

    <label class="reservation-form__field">
      <span>Tarih</span>
      <input type="date" id="res-date" name="date" required />
    </label>

    <label class="reservation-form__field">
      <span>Saat</span>
      <select id="res-time" name="time" required>
        <option value="" disabled selected>Saat seç</option>
        {timeOptions.map((time) => <option value={time}>{time}</option>)}
      </select>
    </label>
  </div>

  <button type="submit" class="reservation-form__submit">
    <span>TALEBİ WHATSAPP’A AKTAR</span>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <div class="reservation-form__status" id="reservation-status" role="status" aria-live="polite"></div>
</form>

<script>
  import { buildReservationWhatsAppUrl } from '@/config/contact';

  const form = document.getElementById('HomeFormReservation') as HTMLFormElement | null;
  const status = document.getElementById('reservation-status');
  const dateInput = document.getElementById('res-date') as HTMLInputElement | null;

  if (dateInput) {
    const now = new Date();
    const localToday = new Date(now.getTime() - now.getTimezoneOffset() * 60_000).toISOString().slice(0, 10);
    dateInput.min = localToday;
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form || !status) return;

    if (!form.checkValidity()) {
      form.reportValidity();
      status.textContent = 'Lütfen ekip, tarih ve saat alanlarını tamamla.';
      status.className = 'reservation-form__status reservation-form__status--error';
      return;
    }

    const formData = new FormData(form);
    const details = {
      name: String(formData.get('name') || ''),
      guests: String(formData.get('guests') || ''),
      date: String(formData.get('date') || ''),
      time: String(formData.get('time') || ''),
    };

    const url = buildReservationWhatsAppUrl(details);
    const popup = window.open(url, '_blank', 'noopener,noreferrer');
    if (!popup) window.location.href = url;

    window.dispatchEvent(new CustomEvent('reservation-intent', { detail: { guests: details.guests } }));
    status.textContent = 'WhatsApp açıldı. Mesajı gönderdiğinde talebin ekibimize ulaşacak.';
    status.className = 'reservation-form__status reservation-form__status--success';
  });
</script>

<style>
  .reservation-form {
    width: 100%;
    padding: clamp(1.25rem, 3vw, 2rem);
    text-align: left;
    border: 1px solid rgba(255,255,255,.13);
    background: rgba(10,9,9,.84);
    box-shadow: 0 25px 80px rgba(0,0,0,.36), inset 0 1px rgba(255,255,255,.04);
    backdrop-filter: blur(15px);
  }

  .reservation-form__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .reservation-form__title {
    color: #f3ede6;
    font: 600 clamp(1rem, 2vw, 1.25rem)/1 var(--font-display);
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .reservation-form__channel {
    display: flex;
    align-items: center;
    gap: .45rem;
    color: #8e8781 !important;
    font-size: .63rem;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .reservation-form__channel span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #25d366;
    box-shadow: 0 0 10px rgba(37,211,102,.65);
  }

  .reservation-form__grid {
    display: grid;
    grid-template-columns: 1.25fr .75fr 1fr .8fr;
    gap: .65rem;
  }

  .reservation-form__field { display: grid; gap: .4rem; min-width: 0; }

  .reservation-form__field > span {
    padding-left: .15rem;
    color: #817a75;
    font-size: .59rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .reservation-form__field input,
  .reservation-form__field select {
    width: 100%;
    height: 50px;
    min-width: 0;
    padding: 0 .9rem;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 0;
    color: #eee8e2;
    background-color: #100e0e;
    font: 500 .82rem var(--font-body);
    color-scheme: dark;
    appearance: none;
  }

  .reservation-form__field select {
    padding-right: 2.2rem;
    background-image: linear-gradient(45deg, transparent 50%, #a69d96 50%), linear-gradient(135deg, #a69d96 50%, transparent 50%);
    background-position: calc(100% - 16px) 22px, calc(100% - 11px) 22px;
    background-size: 5px 5px;
    background-repeat: no-repeat;
  }

  .reservation-form__field input:focus,
  .reservation-form__field select:focus {
    outline: none;
    border-color: #b52a24;
    box-shadow: 0 0 0 3px rgba(181,42,36,.11);
  }

  .reservation-form__field input::placeholder { color: #665f5b; }

  .reservation-form__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .7rem;
    width: 100%;
    min-height: 54px;
    margin-top: .85rem;
    padding: .8rem 1.2rem;
    border: 1px solid #d03931;
    color: #fff;
    background: linear-gradient(135deg, #b31f19, #76120f);
    box-shadow: 0 12px 35px rgba(120,12,10,.25);
    font: 700 .72rem var(--font-body);
    letter-spacing: .13em;
    cursor: pointer;
    transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
  }

  .reservation-form__submit:hover { transform: translateY(-2px); filter: brightness(1.08); box-shadow: 0 16px 42px rgba(160,18,14,.36); }
  .reservation-form__submit:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }

  .reservation-form__status { min-height: 1.2rem; margin-top: .65rem; color: #9a928c !important; font-size: .74rem; text-align: center; }
  .reservation-form__status--success { color: #6fd69b !important; }
  .reservation-form__status--error { color: #ee7c76 !important; }

  @media (max-width: 820px) {
    .reservation-form__grid { grid-template-columns: 1fr 1fr; }
    .reservation-form__field--name { grid-column: span 2; }
  }

  @media (max-width: 520px) {
    .reservation-form { padding: 1rem; }
    .reservation-form__header { align-items: flex-start; flex-direction: column; }
    .reservation-form__grid { grid-template-columns: 1fr; }
    .reservation-form__field--name { grid-column: auto; }
    .reservation-form__channel { font-size: .57rem; }
    .reservation-form__submit span { letter-spacing: .08em; }
  }
</style>
