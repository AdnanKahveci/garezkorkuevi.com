---
// Footer
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__copy">&copy; {year} Garez Korku Evi. Tüm hakları saklıdır.</p>
    <nav class="site-footer__nav" aria-label="Alt navigasyon">
      <a href="/#anasayfa" data-nav-section>Ana Sayfa</a>
      <a href="/#galeri-bolum" data-nav-section>Galeri</a>
      <a href="/#rezervasyon" data-nav-section>Rezervasyon</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    background: #0a0a0a;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 2rem 1.5rem;
  }
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .site-footer__copy { color: #555; font-size: 0.8rem; }
  .site-footer__nav { display: flex; gap: 1.5rem; }
  .site-footer__nav a {
    color: #666;
    text-decoration: none;
    font-size: 0.8rem;
  }
  .site-footer__nav a:hover { color: #aaa; }
</style>
