---
// HorrorHands - Kenarlardan uzanan eller (GAREZ tarzı)
---

<div class="horror-hands" aria-hidden="true">
  <div class="horror-hands__hand horror-hands__hand--top">
    <svg viewBox="0 0 200 280" xmlns="http://www.w3.org/2000/svg">
      <path d="M60,280 L55,180 Q50,120 70,80 Q90,40 100,0 Q110,40 130,80 Q150,120 145,180 L140,280 Z" fill="#8a7a6a" opacity="0.85"/>
      <path d="M75,200 L65,140 M100,190 L100,120 M125,200 L135,140" stroke="#5a4a3a" stroke-width="3" fill="none"/>
      <ellipse cx="85" cy="60" rx="12" ry="18" fill="#7a6a5a"/>
      <ellipse cx="100" cy="45" rx="10" ry="16" fill="#7a6a5a"/>
      <ellipse cx="115" cy="60" rx="12" ry="18" fill="#7a6a5a"/>
      <ellipse cx="72" cy="85" rx="10" ry="14" fill="#7a6a5a"/>
      <ellipse cx="128" cy="85" rx="10" ry="14" fill="#7a6a5a"/>
    </svg>
  </div>
  <div class="horror-hands__hand horror-hands__hand--left">
    <svg viewBox="0 0 160 200" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,100 Q40,80 80,90 Q120,100 160,70 L160,200 L0,200 Z" fill="#7a6a5a" opacity="0.9"/>
      <ellipse cx="30" cy="110" rx="14" ry="20" fill="#6a5a4a" transform="rotate(-20 30 110)"/>
      <ellipse cx="55" cy="95" rx="12" ry="18" fill="#6a5a4a"/>
      <ellipse cx="80" cy="88" rx="11" ry="16" fill="#6a5a4a"/>
      <ellipse cx="105" cy="82" rx="10" ry="14" fill="#6a5a4a"/>
      <ellipse cx="130" cy="75" rx="9" ry="12" fill="#6a5a4a"/>
    </svg>
  </div>
  <div class="horror-hands__hand horror-hands__hand--right">
    <svg viewBox="0 0 160 200" xmlns="http://www.w3.org/2000/svg">
      <path d="M160,100 Q120,80 80,90 Q40,100 0,70 L0,200 L160,200 Z" fill="#7a6a5a" opacity="0.9"/>
      <ellipse cx="130" cy="110" rx="14" ry="20" fill="#6a5a4a" transform="rotate(20 130 110)"/>
      <ellipse cx="105" cy="95" rx="12" ry="18" fill="#6a5a4a"/>
      <ellipse cx="80" cy="88" rx="11" ry="16" fill="#6a5a4a"/>
      <ellipse cx="55" cy="82" rx="10" ry="14" fill="#6a5a4a"/>
      <ellipse cx="30" cy="75" rx="9" ry="12" fill="#6a5a4a"/>
    </svg>
  </div>
</div>

<style>
  .horror-hands {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 6;
    overflow: hidden;
  }

  .horror-hands__hand {
    position: absolute;
    filter: drop-shadow(0 0 20px rgba(0,0,0,0.8));
  }

  .horror-hands__hand svg {
    width: 100%;
    height: 100%;
  }

  .horror-hands__hand--top {
    top: -8%;
    left: 50%;
    width: clamp(120px, 18vw, 200px);
    height: clamp(160px, 24vw, 280px);
    transform: translateX(-50%);
    animation: handReachTop 6s ease-in-out infinite alternate;
  }

  .horror-hands__hand--left {
    left: -5%;
    top: 35%;
    width: clamp(100px, 14vw, 160px);
    height: clamp(130px, 18vw, 200px);
    animation: handReachLeft 5s ease-in-out infinite alternate;
  }

  .horror-hands__hand--right {
    right: -5%;
    top: 40%;
    width: clamp(100px, 14vw, 160px);
    height: clamp(130px, 18vw, 200px);
    animation: handReachRight 5.5s ease-in-out infinite alternate;
  }

  @keyframes handReachTop {
    from { transform: translateX(-50%) translateY(0); }
    to { transform: translateX(-50%) translateY(25px); }
  }

  @keyframes handReachLeft {
    from { transform: translateX(0); }
    to { transform: translateX(30px); }
  }

  @keyframes handReachRight {
    from { transform: translateX(0); }
    to { transform: translateX(-30px); }
  }

  @media (max-width: 768px) {
    .horror-hands__hand--top { width: 100px; height: 140px; opacity: 0.6; }
    .horror-hands__hand--left,
    .horror-hands__hand--right { opacity: 0.5; width: 80px; height: 110px; }
  }

  body.reduced-motion-active .horror-hands__hand {
    animation: none;
  }
</style>
