---
// SectionWebReveal - Scroll ile sağdan/soldan giren örümcek ağı
interface Props {
  side?: 'left' | 'right';
  sectionId?: string;
}
const { side = 'right', sectionId = '' } = Astro.props;
---

<div
  class={`web-reveal web-reveal--${side}`}
  data-web-reveal
  data-trigger={sectionId}
  aria-hidden="true"
>
  <svg class="web-reveal__svg" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg">
    <g class="web-reveal__strands">
      <line x1="0" y1="0" x2="240" y2="240" stroke="rgba(210,210,210,0.22)" stroke-width="0.6"/>
      <line x1="0" y1="0" x2="240" y2="120" stroke="rgba(210,210,210,0.18)" stroke-width="0.5"/>
      <line x1="0" y1="0" x2="120" y2="240" stroke="rgba(210,210,210,0.18)" stroke-width="0.5"/>
      <line x1="0" y1="0" x2="240" y2="60" stroke="rgba(210,210,210,0.14)" stroke-width="0.4"/>
      <line x1="0" y1="0" x2="60" y2="240" stroke="rgba(210,210,210,0.14)" stroke-width="0.4"/>
      <path d="M0,0 Q120,70 240,140" fill="none" stroke="rgba(210,210,210,0.12)" stroke-width="0.4"/>
      <path d="M0,0 Q70,120 140,240" fill="none" stroke="rgba(210,210,210,0.12)" stroke-width="0.4"/>
      <circle cx="80" cy="80" r="3" fill="rgba(180,180,180,0.15)"/>
      <circle cx="140" cy="50" r="2" fill="rgba(180,180,180,0.1)"/>
    </g>
  </svg>
</div>

<style>
  .web-reveal {
    position: absolute;
    width: 220px;
    height: 220px;
    pointer-events: none;
    z-index: 4;
    opacity: 0.85;
    will-change: transform, opacity;
  }

  .web-reveal--left {
    top: 10%;
    left: -220px;
  }

  .web-reveal--right {
    top: 15%;
    right: -220px;
    transform: scaleX(-1);
  }

  .web-reveal__svg {
    width: 100%;
    height: 100%;
    animation: webSwayReveal 5s ease-in-out infinite alternate;
  }

  @keyframes webSwayReveal {
    to { transform: rotate(2deg); }
  }

  @media (max-width: 768px) {
    .web-reveal { width: 120px; height: 120px; opacity: 0.5; }
    .web-reveal--right { display: none; }
  }

  body.reduced-motion-active .web-reveal {
    opacity: 0.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .web-reveal { opacity: 0.6; }
    .web-reveal__svg { animation: none; }
  }
</style>
