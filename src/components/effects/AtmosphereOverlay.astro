---
// AtmosphereOverlay - Net görünüm: grain yok, hafif kan damlası
---

<div class="atmosphere" aria-hidden="true">
  <div class="atmosphere__blood atmosphere__blood--1"></div>
  <div class="atmosphere__blood atmosphere__blood--2"></div>
  <div class="atmosphere__drip atmosphere__drip--1"></div>
  <div class="atmosphere__drip atmosphere__drip--2"></div>
  <div class="atmosphere__vignette"></div>
</div>

<style>
  .atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 34;
    overflow: hidden;
  }

  .atmosphere__blood {
    position: absolute;
    border-radius: 50% 40% 55% 45%;
    background: #6a0000;
    opacity: 0.45;
  }

  .atmosphere__blood--1 {
    width: 72px;
    height: 56px;
    top: 6%;
    left: 4%;
    transform: rotate(-16deg);
  }

  .atmosphere__blood--2 {
    width: 48px;
    height: 40px;
    top: 14%;
    right: 7%;
    transform: rotate(22deg);
    opacity: 0.35;
  }

  .atmosphere__drip {
    position: absolute;
    top: 0;
    width: 3px;
    height: 0;
    background: linear-gradient(180deg, #9a0000 0%, #d01010 50%, transparent 100%);
    border-radius: 0 0 3px 3px;
    opacity: 0.65;
    animation: bloodDrip 8s ease-in infinite;
  }

  .atmosphere__drip--1 { left: 16%; }
  .atmosphere__drip--2 {
    left: 72%;
    width: 2px;
    animation-delay: -3s;
    opacity: 0.45;
  }

  @keyframes bloodDrip {
    0% { height: 0; opacity: 0; }
    15% { opacity: 0.65; }
    60% { height: 140px; opacity: 0.55; }
    100% { height: 190px; opacity: 0; }
  }

  .atmosphere__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 65%, rgba(0,0,0,0.45) 100%);
  }

  @media (max-width: 768px), (pointer: coarse) {
    .atmosphere__blood { opacity: 0.25; }
    .atmosphere__drip { animation: none; height: 60px; opacity: 0.3; }
  }

  body.reduced-motion-active .atmosphere__drip,
  body.lite-mode .atmosphere__drip {
    animation: none;
    height: 70px;
    opacity: 0.28;
  }
</style>
