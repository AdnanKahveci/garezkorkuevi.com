---
// Gerçek AudioContext durumunu gösteren ses kontrolü.
---

<div class="audio-controller" id="audio-controller">
  <button
    type="button"
    class="audio-controller__toggle audio-controller__toggle--muted"
    id="audio-toggle"
    aria-label="Sesi aç"
    aria-pressed="false"
    title="Atmosfer sesini aç"
  >
    <span class="audio-controller__signal" aria-hidden="true"></span>
    <svg class="audio-icon audio-icon--on" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
    </svg>
    <svg class="audio-icon audio-icon--off" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zM4.27 3 3 4.27 7.73 9H3v6h4l5 5v-6.73l5.73 5.73L21 19.73l-9-9L4.27 3zM12 4 9.91 6.09 12 8.18V4z"/>
    </svg>
    <span class="audio-controller__label">SES KAPALI</span>
  </button>
  <div class="audio-controller__slider-wrap">
    <label for="volume-slider" class="sr-only">Ses seviyesi</label>
    <input type="range" id="volume-slider" class="audio-controller__slider" min="0" max="100" value="72" aria-label="Ses seviyesi" disabled />
  </div>
</div>

<script>
  import { audioManager } from '@/lib/audio/AudioManager';
  import { bootstrapSoundExperience } from '@/lib/audio/bootstrapAudio';
  import { savePreferences } from '@/lib/scare-engine/ExperienceState';

  function initAudioController() {
    const toggle = document.getElementById('audio-toggle') as HTMLButtonElement | null;
    const slider = document.getElementById('volume-slider') as HTMLInputElement | null;
    const label = toggle?.querySelector('.audio-controller__label');
    if (!toggle || !slider || !label) return;

    function updateUI() {
      const active = audioManager.isMasterEnabled() && audioManager.isContextRunning();
      toggle!.classList.toggle('audio-controller__toggle--muted', !active);
      toggle!.setAttribute('aria-pressed', String(active));
      toggle!.setAttribute('aria-label', active ? 'Sesi kapat' : 'Sesi aç');
      toggle!.title = active ? 'Atmosfer sesini kapat' : 'Atmosfer sesini aç';
      label!.textContent = active ? 'SES AÇIK' : 'SES KAPALI';
      slider!.disabled = !active;
    }

    toggle.addEventListener('click', async () => {
      const active = audioManager.isMasterEnabled() && audioManager.isContextRunning();
      toggle.disabled = true;

      if (active) {
        audioManager.setMasterEnabled(false);
        savePreferences({ audio: 'silent' });
      } else {
        const started = await bootstrapSoundExperience();
        if (started) savePreferences({ audio: 'sound' });
      }

      toggle.disabled = false;
      updateUI();
    });

    slider.addEventListener('input', () => {
      audioManager.setChannelVolume('master', Number(slider.value) / 100);
    });

    window.addEventListener('audio-ready', (event) => {
      const volume = (event as CustomEvent<{ volume?: number }>).detail?.volume;
      if (typeof volume === 'number') slider.value = String(Math.round(volume * 100));
      updateUI();
    });

    window.addEventListener('experience-prefs-changed', updateUI);
    updateUI();
  }

  initAudioController();
</script>

<style>
  .audio-controller { display: flex; align-items: center; gap: .55rem; }

  .audio-controller__toggle {
    position: relative;
    display: flex;
    align-items: center;
    gap: .48rem;
    min-height: 36px;
    padding: 0 .72rem;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 999px;
    color: #e6dfd8;
    background: rgba(255,255,255,.045);
    cursor: pointer;
    transition: border-color .2s, background .2s, opacity .2s;
  }

  .audio-controller__toggle:hover { border-color: rgba(220,54,46,.6); background: rgba(150,20,20,.11); }
  .audio-controller__toggle:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .audio-controller__toggle:disabled { cursor: wait; opacity: .55; }

  .audio-controller__signal {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #e6322b;
    box-shadow: 0 0 8px rgba(230,50,43,.75);
  }

  .audio-controller__label { font-size: .56rem; font-weight: 700; letter-spacing: .12em; white-space: nowrap; }
  .audio-icon--off { display: none; }
  .audio-controller__toggle--muted { color: #8d8782; }
  .audio-controller__toggle--muted .audio-controller__signal { background: #5c5855; box-shadow: none; }
  .audio-controller__toggle--muted .audio-icon--on { display: none; }
  .audio-controller__toggle--muted .audio-icon--off { display: block; }

  .audio-controller__slider {
    display: block;
    width: 68px;
    height: 3px;
    accent-color: #b9231d;
    cursor: pointer;
  }

  .audio-controller__slider:disabled { opacity: .28; }

  @media (max-width: 850px) {
    .audio-controller__slider-wrap, .audio-controller__label { display: none; }
    .audio-controller__toggle { width: 36px; padding: 0; justify-content: center; }
    .audio-controller__signal { position: absolute; top: 3px; right: 3px; }
  }
</style>
