---
// GlitchText - Glitch efektli metin
interface Props {
  text: string;
  tag?: 'span';
  class?: string;
}
const { text, class: className = '' } = Astro.props;
---

<span class={`glitch-text ${className}`} data-glitch data-text={text}>
  {text}
</span>

<style>
  .glitch-text {
    position: relative;
    display: inline-block;
    animation: glitchIdle 6s ease-in-out infinite;
  }

  @keyframes glitchIdle {
    0%, 92%, 100% { text-shadow: inherit; }
    93% { text-shadow: 3px 0 #ff0040, -3px 0 #00ffff; transform: skewX(-1deg); }
    94% { text-shadow: -2px 0 #ff0040, 2px 0 #00ffff; transform: skewX(1deg); }
    95% { text-shadow: inherit; transform: none; }
  }
  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
  }
  .glitch-text.glitch-active::before {
    color: #ff0040;
    opacity: 0.7;
    animation: glitchShift1 0.3s steps(3);
    clip-path: inset(20% 0 30% 0);
  }
  .glitch-text.glitch-active::after {
    color: #00ffff;
    opacity: 0.7;
    animation: glitchShift2 0.3s steps(3);
    clip-path: inset(50% 0 10% 0);
  }
  @keyframes glitchShift1 {
    0% { transform: translate(0); }
    33% { transform: translate(-3px, 2px); }
    66% { transform: translate(3px, -1px); }
    100% { transform: translate(0); }
  }
  @keyframes glitchShift2 {
    0% { transform: translate(0); }
    33% { transform: translate(3px, -2px); }
    66% { transform: translate(-2px, 1px); }
    100% { transform: translate(0); }
  }
</style>
