---
// HeroAtmosphere - Ahşap tahta, kırmızı göz, kan lekeleri, otomatik animasyonlar
---

<div class="hero-atmo" aria-hidden="true">
  <div class="hero-atmo__wood"></div>
  <div class="hero-atmo__crack"></div>
  <div class="hero-atmo__blood hero-atmo__blood--1"></div>
  <div class="hero-atmo__blood hero-atmo__blood--2"></div>
  <div class="hero-atmo__eye-glow"></div>
  <div class="hero-atmo__eyes">
    <span class="hero-atmo__eye"></span>
    <span class="hero-atmo__eye"></span>
  </div>
  <div class="hero-atmo__pass-shadow hero-atmo__pass-shadow--1">
    <img src="/images/jumpscare/garez-yuz.png" alt="" class="hero-atmo__pass-img" loading="eager" decoding="async" />
  </div>
  <div class="hero-atmo__pass-shadow hero-atmo__pass-shadow--2">
    <img src="/images/jumpscare/garez-yuz.png" alt="" class="hero-atmo__pass-img" loading="eager" decoding="async" />
  </div>
</div>

<style>
  .hero-atmo {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 4;
    overflow: hidden;
  }

  .hero-atmo__wood {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 80px,
        rgba(0,0,0,0.15) 80px,
        rgba(0,0,0,0.15) 82px
      ),
      linear-gradient(180deg, rgba(30,15,10,0.4) 0%, rgba(10,5,5,0.7) 100%),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='w'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.04 0.8' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23w)' opacity='0.15'/%3E%3C/svg%3E");
    opacity: 0.7;
  }

  .hero-atmo__crack {
    position: absolute;
    top: 15%;
    left: 50%;
    width: 4px;
    height: 55%;
    transform: translateX(-50%);
    background: linear-gradient(180deg, transparent, #c41e1e 20%, #8b0000 50%, transparent);
    box-shadow: 0 0 30px rgba(196,30,30,0.6), 0 0 60px rgba(139,0,0,0.3);
    animation: crackPulse 3s ease-in-out infinite;
  }

  .hero-atmo__blood {
    position: absolute;
    border-radius: 50% 40% 60% 30%;
    background: radial-gradient(ellipse, rgba(139,0,0,0.65) 0%, rgba(80,0,0,0.3) 60%, transparent 80%);
  }

  .hero-atmo__blood--1 {
    width: 120px;
    height: 90px;
    top: 8%;
    left: 5%;
    animation: bloodDrip 8s ease-in-out infinite;
  }

  .hero-atmo__blood--2 {
    width: 80px;
    height: 60px;
    bottom: 20%;
    right: 8%;
    animation: bloodDrip 10s ease-in-out infinite reverse;
  }

  .hero-atmo__eye-glow {
    position: absolute;
    top: 38%;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    height: 60px;
    background: radial-gradient(ellipse, rgba(196,30,30,0.25) 0%, transparent 70%);
    animation: eyeGlowPulse 2s ease-in-out infinite alternate;
  }

  .hero-atmo__eyes {
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 50px;
    opacity: 0;
    animation: eyesPeek 8s ease-in-out infinite;
  }

  .hero-atmo__eye {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: radial-gradient(circle, #ff2222 30%, #8b0000 70%, #000 100%);
    box-shadow: 0 0 20px #ff0000, 0 0 40px rgba(255,0,0,0.5);
    animation: eyeBlink 4s ease infinite;
  }

  .hero-atmo__pass-shadow {
    position: absolute;
    top: 45%;
    width: 180px;
    height: 280px;
    opacity: 0;
  }

  .hero-atmo__pass-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 0 15px rgba(139,0,0,0.7)) contrast(1.15);
  }

  .hero-atmo__pass-shadow--1 {
    left: -200px;
    animation: shadowPassLeft 12s linear infinite;
    animation-delay: 1s;
  }

  .hero-atmo__pass-shadow--2 {
    right: -200px;
    transform: scaleX(-1);
    animation: shadowPassRight 14s linear infinite;
    animation-delay: 6s;
  }

  @keyframes crackPulse {
    0%, 100% { opacity: 0.6; box-shadow: 0 0 20px rgba(196,30,30,0.4); }
    50% { opacity: 1; box-shadow: 0 0 50px rgba(196,30,30,0.8); }
  }

  @keyframes bloodDrip {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1) translateY(5px); opacity: 0.8; }
  }

  @keyframes eyeGlowPulse {
    to { opacity: 0.6; transform: translateX(-50%) scale(1.2); }
  }

  @keyframes eyesPeek {
    0%, 70%, 100% { opacity: 0; transform: translateX(-50%) translateY(20px); }
    75%, 85% { opacity: 0.9; transform: translateX(-50%) translateY(0); }
  }

  @keyframes eyeBlink {
    0%, 96%, 100% { transform: scaleY(1); }
    98% { transform: scaleY(0.1); }
  }

  @keyframes shadowPassLeft {
    0% { left: -200px; opacity: 0; }
    5% { opacity: 0.85; }
    45% { opacity: 0.85; }
    50% { left: 110%; opacity: 0; }
    100% { left: 110%; opacity: 0; }
  }

  @keyframes shadowPassRight {
    0% { right: -200px; opacity: 0; }
    5% { opacity: 0.85; }
    45% { opacity: 0.85; }
    50% { right: 110%; opacity: 0; }
    100% { right: 110%; opacity: 0; }
  }

  body.reduced-motion-active .hero-atmo__pass-shadow,
  body.reduced-motion-active .hero-atmo__eyes,
  body.reduced-motion-active .hero-atmo__crack {
    animation: none;
  }

  @media (max-width: 768px) {
    .hero-atmo__pass-shadow { width: 120px; height: 180px; }
    .hero-atmo__eyes { gap: 30px; }
    .hero-atmo__eye { width: 16px; height: 16px; }
  }
</style>
