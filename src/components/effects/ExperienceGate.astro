---
// Tarayıcılar kullanıcı etkileşimi olmadan ses başlatamaz; bu kapı açık izin sağlar.
---

<div id="experience-gate" class="experience-gate" role="dialog" aria-modal="true" aria-labelledby="gate-title" aria-describedby="gate-description">
  <div class="experience-gate__image" aria-hidden="true"></div>
  <div class="experience-gate__noise" aria-hidden="true"></div>

  <div class="experience-gate__content">
    <div class="experience-gate__brand" aria-hidden="true">
      <span>G</span>
      <p>GAREZ<br />KORKU EVİ</p>
    </div>
    <p class="experience-gate__eyebrow">ETKİLEŞİMLİ KORKU DENEYİMİ</p>
    <h2 id="gate-title" class="experience-gate__title">Karanlık<br /><em>sesle başlar.</em></h2>
    <p id="gate-description" class="experience-gate__subtitle">
      Atmosfer ve ani efektler sesle birlikte tasarlandı. Kontrol her zaman sende.
    </p>

    <div class="experience-gate__actions">
      <button type="button" class="gate-btn gate-btn--primary" data-choice="sound">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm11 7.5v-9a5 5 0 0 1 0 9zm0-13v2.06a7 7 0 0 1 0 12.88v2.06A9 9 0 0 0 14 3.5z"/></svg>
        <span>Sesli deneyime gir <small>ÖNERİLEN</small></span>
      </button>
      <button type="button" class="gate-btn gate-btn--secondary" data-choice="silent">
        Sessiz incele
      </button>
    </div>

    <label class="experience-gate__motion">
      <input type="checkbox" id="gate-reduced-motion" />
      <span>Animasyonları ve ani efektleri azalt</span>
    </label>

    <p class="experience-gate__status" id="gate-status" role="status" aria-live="polite"></p>

    <details class="experience-gate__warning">
      <summary>Hassasiyet uyarısı</summary>
      <p>Bu deneyim ani ses, ışık değişimi ve kontrollü korku efektleri içerir. Epilepsi, migren veya panik atak hassasiyetiniz varsa sessiz ve azaltılmış hareket seçeneğini kullanın.</p>
    </details>
  </div>

  <p class="experience-gate__foot" aria-hidden="true">KULAKLIKLA DAHA ETKİLİDİR</p>
</div>

<script>
  import { bootstrapSoundExperience, ensureGestureAudioUnlock } from '@/lib/audio/bootstrapAudio';
  import { audioManager } from '@/lib/audio/AudioManager';
  import { getPreferences, savePreferences } from '@/lib/scare-engine/ExperienceState';

  function preloadJumpscareAssets() {
    document.querySelectorAll<HTMLImageElement>('img[data-horror-src]').forEach((image) => {
      const source = image.dataset.horrorSrc;
      if (source && !image.getAttribute('src')) image.src = source;
    });
  }

  function activateExperience() {
    document.body.style.overflow = '';
    document.body.classList.add('experience-active', 'horror-live');
    window.dispatchEvent(new CustomEvent('experience-started'));
  }

  function dismissGate(gate: HTMLElement) {
    gate.classList.add('experience-gate--exit');
    gate.style.pointerEvents = 'none';

    const remove = () => gate.remove();
    gate.addEventListener('animationend', remove, { once: true });
    window.setTimeout(remove, 650);
  }

  async function handleChoice(gate: HTMLElement, choice: 'sound' | 'silent') {
    const status = document.getElementById('gate-status');
    const reduceMotion = (document.getElementById('gate-reduced-motion') as HTMLInputElement | null)?.checked ?? false;
    const motion = reduceMotion ? 'reduced' : 'full';

    if (reduceMotion) document.body.classList.add('reduced-motion-active');

    if (choice === 'sound') {
      if (status) status.textContent = 'Ses ortamı hazırlanıyor…';
      const started = await bootstrapSoundExperience();
      if (!started) {
        if (status) status.textContent = 'Tarayıcı sesi başlatamadı. Tekrar deneyin veya sessiz devam edin.';
        gate.querySelectorAll<HTMLButtonElement>('[data-choice]').forEach((button) => { button.disabled = false; });
        return;
      }
    } else {
      audioManager.setMasterEnabled(false);
    }

    savePreferences({
      audio: choice,
      motion,
      fearLevel: reduceMotion ? 'light' : 'normal',
      jumpscareEnabled: !reduceMotion,
      gatePassed: true,
      sessionStarted: true,
    });

    try { preloadJumpscareAssets(); } catch { /* Görsel ön yüklemesi kritik değil. */ }
    activateExperience();
    dismissGate(gate);
  }

  function initGate() {
    const gate = document.getElementById('experience-gate');
    if (!gate) return;

    const prefs = getPreferences();
    if (prefs.gatePassed) {
      gate.remove();
      if (prefs.motion === 'reduced') document.body.classList.add('reduced-motion-active');
      if (prefs.audio === 'sound') ensureGestureAudioUnlock();
      else audioManager.setMasterEnabled(false);
      try { preloadJumpscareAssets(); } catch { /* ignore */ }
      activateExperience();
      return;
    }

    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => gate.classList.add('experience-gate--visible'));
    (gate.querySelector('[data-choice="sound"]') as HTMLButtonElement | null)?.focus();

    gate.querySelectorAll<HTMLButtonElement>('[data-choice]').forEach((button) => {
      button.addEventListener('click', async () => {
        gate.querySelectorAll<HTMLButtonElement>('[data-choice]').forEach((item) => { item.disabled = true; });
        await handleChoice(gate, button.dataset.choice as 'sound' | 'silent');
      });
    });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initGate, { once: true });
  else initGate();
</script>

<style>
  .experience-gate {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: none;
    place-items: center;
    min-height: 100dvh;
    overflow: auto;
    padding: clamp(1.25rem, 4vw, 3rem);
    background: #050505;
    opacity: 0;
  }

  :global(.js) .experience-gate { display: grid; }
  .experience-gate--visible { opacity: 1; }
  .experience-gate--exit { animation: gateExit .55s cubic-bezier(.7,0,.3,1) forwards; }

  @keyframes gateExit {
    to { opacity: 0; filter: blur(7px); transform: scale(1.02); }
  }

  .experience-gate__image {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(3,3,3,.78), rgba(3,3,3,.42) 52%, rgba(3,3,3,.76)),
      linear-gradient(0deg, #050505 0%, transparent 38%),
      url('/images/horror/garez-hero-v2.webp') center / cover no-repeat;
    filter: saturate(.55) contrast(1.08) brightness(.6);
  }

  .experience-gate__noise {
    position: absolute;
    inset: 0;
    opacity: .08;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.5'/%3E%3C/svg%3E");
  }

  .experience-gate__content {
    position: relative;
    width: min(100%, 590px);
    padding: clamp(1.5rem, 5vw, 3rem);
    border: 1px solid rgba(255,255,255,.12);
    background: linear-gradient(145deg, rgba(11,10,10,.9), rgba(8,7,7,.76));
    box-shadow: 0 30px 100px rgba(0,0,0,.72), inset 0 1px rgba(255,255,255,.04);
    backdrop-filter: blur(18px);
  }

  .experience-gate__content::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(160,20,20,.18);
    pointer-events: none;
  }

  .experience-gate__brand {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 2.5rem;
  }

  .experience-gate__brand > span {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid #982323;
    color: #e93f35;
    font: 700 1.2rem/1 var(--font-display);
  }

  .experience-gate__brand p {
    color: #bcb5ae;
    font: 600 .58rem/1.35 var(--font-display);
    letter-spacing: .22em;
  }

  .experience-gate__eyebrow {
    color: #d34038;
    font-size: .63rem;
    font-weight: 700;
    letter-spacing: .27em;
    margin-bottom: .8rem;
  }

  .experience-gate__title {
    color: #f6f1ea;
    font: 600 clamp(2.1rem, 7vw, 4.25rem)/.98 var(--font-display);
    letter-spacing: -.035em;
    text-wrap: balance;
  }

  .experience-gate__title em { color: #ba2923; font-style: normal; }

  .experience-gate__subtitle {
    max-width: 470px;
    margin: 1.4rem 0 1.8rem;
    color: #b3aba4;
    font-size: .93rem;
    line-height: 1.65;
  }

  .experience-gate__actions { display: flex; gap: .65rem; flex-wrap: wrap; }

  .gate-btn {
    min-height: 52px;
    padding: .8rem 1.25rem;
    border: 1px solid transparent;
    font: 700 .75rem/1 var(--font-body);
    letter-spacing: .06em;
    cursor: pointer;
    transition: transform .2s ease, border-color .2s ease, background .2s ease;
  }

  .gate-btn:focus-visible { outline: 2px solid #fff; outline-offset: 3px; }
  .gate-btn:hover:not(:disabled) { transform: translateY(-2px); }
  .gate-btn:disabled { cursor: wait; opacity: .55; }

  .gate-btn--primary {
    flex: 1 1 285px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .65rem;
    color: #fff;
    background: linear-gradient(135deg, #b51e18, #71110f);
    border-color: #d83c33;
    box-shadow: 0 14px 35px rgba(139,0,0,.32);
  }

  .gate-btn--primary span { display: flex; align-items: center; gap: .55rem; }
  .gate-btn--primary small { font-size: .5rem; padding: .25rem .36rem; border: 1px solid rgba(255,255,255,.38); }

  .gate-btn--secondary {
    flex: 1 1 135px;
    color: #c7c0ba;
    background: rgba(255,255,255,.04);
    border-color: rgba(255,255,255,.15);
  }

  .experience-gate__motion {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    margin-top: 1rem;
    color: #958d87;
    font-size: .72rem;
    cursor: pointer;
  }

  .experience-gate__motion input { accent-color: #a91d19; }
  .experience-gate__status { min-height: 1.2rem; margin-top: .6rem; color: #d4a39f; font-size: .72rem; }

  .experience-gate__warning {
    margin-top: 1.2rem;
    padding-top: .85rem;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #756f6a;
    font-size: .67rem;
  }

  .experience-gate__warning summary { width: max-content; cursor: pointer; color: #8f8882; }
  .experience-gate__warning p { margin-top: .55rem; line-height: 1.55; }

  .experience-gate__foot {
    position: absolute;
    bottom: max(1rem, env(safe-area-inset-bottom));
    color: rgba(255,255,255,.28);
    font-size: .55rem;
    letter-spacing: .28em;
  }

  @media (max-width: 540px) {
    .experience-gate { align-items: start; padding: .75rem; }
    .experience-gate__content { width: calc(100vw - 1.5rem); max-width: none; min-width: 0; margin: auto 0; padding: 1.35rem; overflow: hidden; }
    .experience-gate__brand { margin-bottom: 1.5rem; }
    .experience-gate__actions { flex-direction: column; }
    .gate-btn--primary, .gate-btn--secondary { flex-basis: auto; width: 100%; }
    .experience-gate__foot { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .experience-gate--exit { animation: gateExitReduced .25s ease forwards; }
    @keyframes gateExitReduced { to { opacity: 0; } }
  }
</style>
