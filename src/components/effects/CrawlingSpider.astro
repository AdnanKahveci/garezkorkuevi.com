---
// CrawlingSpider - Ağ üzerinde hareket eden örümcek
interface Props {
  delay?: number;
  pathId?: string;
}
const { delay = 0, pathId = 'spider-path-1' } = Astro.props;
---

<div
  class="crawling-spider"
  style={`animation-delay: ${delay}s`}
  aria-hidden="true"
>
  <svg class="crawling-spider__path-def" width="0" height="0">
    <defs>
      <path id={pathId} d="M10,10 Q80,40 150,80 Q120,120 60,150 Q30,100 10,10" fill="none"/>
    </defs>
  </svg>
  <div class="crawling-spider__body" style={`offset-path: path('#${pathId}')`}>
    <svg width="14" height="14" viewBox="0 0 12 12" fill="rgba(180,40,40,0.9)">
      <circle cx="6" cy="4" r="3"/>
      <line x1="3" y1="5" x2="1" y2="8" stroke="rgba(140,30,30,0.8)" stroke-width="0.6"/>
      <line x1="9" y1="5" x2="11" y2="8" stroke="rgba(140,30,30,0.8)" stroke-width="0.6"/>
      <line x1="4" y1="6" x2="2" y2="10" stroke="rgba(140,30,30,0.8)" stroke-width="0.6"/>
      <line x1="8" y1="6" x2="10" y2="10" stroke="rgba(140,30,30,0.8)" stroke-width="0.6"/>
    </svg>
  </div>
</div>

<style>
  .crawling-spider {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .crawling-spider__body {
    width: 12px;
    height: 12px;
    offset-rotate: auto;
    animation: spiderCrawl 18s linear infinite;
    animation-delay: inherit;
  }
  @keyframes spiderCrawl {
    0% { offset-distance: 0%; }
    100% { offset-distance: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .crawling-spider__body { animation: none; display: none; }
  }
</style>
