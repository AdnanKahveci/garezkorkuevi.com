---
// JumpscareController - Uzun jumpscare + randevu CTA
import { JUMPSCARE_FACE_IMAGE } from '@/config/jumpscare';
---

<div id="jumpscare-overlay" class="jumpscare" role="alert" aria-live="assertive">
  <div class="jumpscare__flash" aria-hidden="true"></div>
  <div class="jumpscare__red-pulse" aria-hidden="true"></div>
  <div class="jumpscare__vignette" aria-hidden="true"></div>

  <div class="jumpscare__shadow jumpscare__shadow--left" aria-hidden="true">
    <img data-horror-src="/images/jumpscare/garez-yuz.png" alt="" class="jumpscare__shadow-img" />
  </div>
  <div class="jumpscare__shadow jumpscare__shadow--right" aria-hidden="true">
    <img data-horror-src="/images/jumpscare/garez-yuz.png" alt="" class="jumpscare__shadow-img" />
  </div>

  <div class="jumpscare__image" aria-hidden="true">
    <div class="jumpscare__stage">
      <div class="jumpscare__face-glow" aria-hidden="true"></div>
      <div class="jumpscare__face-wrap jumpscare__face-wrap--photo">
        <img data-horror-src={JUMPSCARE_FACE_IMAGE} alt="" class="jumpscare__face" />
      </div>
      <p class="jumpscare__scream" aria-hidden="true">BORCUN HAZIR...</p>
      <a href="#rezervasyon" class="jumpscare__quick-book" id="jumpscare-quick-book">
        RANDEVU OLUŞTUR <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>

  <div class="jumpscare__cta" id="jumpscare-cta" hidden>
    <p class="jumpscare__cta-eyebrow">Hâlâ ayaktasın...</p>
    <h2 class="jumpscare__cta-title">RANDEVU OLUŞTUR</h2>
    <p class="jumpscare__cta-sub">Cesaretini kanıtla. Gareze gerçekten girmeye hazır mısın?</p>
    <div class="jumpscare__cta-actions">
      <a href="#rezervasyon" class="jumpscare__cta-btn" id="jumpscare-cta-book">
        Randevu Oluştur
      </a>
    </div>
  </div>

  <button type="button" class="jumpscare__dismiss" id="jumpscare-dismiss" aria-label="Kapat">
    ✕
  </button>
</div>

<style>
  .jumpscare {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s;
  }

  .jumpscare--active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .jumpscare--shake {
    animation: scareShake 0.08s linear infinite;
  }

  @keyframes scareShake {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-6px, 4px); }
    50% { transform: translate(5px, -5px); }
    75% { transform: translate(-4px, -3px); }
  }

  .jumpscare__flash {
    position: absolute;
    inset: 0;
    background: #fff;
    opacity: 0;
    z-index: 5;
    pointer-events: none;
  }

  .jumpscare__flash--on {
    animation: scareFlash 0.12s ease-out forwards;
  }

  @keyframes scareFlash {
    0% { opacity: 0.9; }
    100% { opacity: 0; }
  }

  .jumpscare__red-pulse {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(180,0,0,0.5) 0%, rgba(0,0,0,0.9) 70%);
    opacity: 0;
    z-index: 1;
    pointer-events: none;
  }

  .jumpscare__red-pulse--on {
    animation: redPulseScare 0.6s ease-in-out infinite alternate;
  }

  @keyframes redPulseScare {
    to { opacity: 0.85; }
  }

  .jumpscare__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.85) 100%);
    opacity: 0;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .jumpscare--active .jumpscare__vignette {
    opacity: 1;
  }

  .jumpscare__shadow {
    position: fixed;
    top: 30%;
    width: 300px;
    height: 420px;
    z-index: 3;
    pointer-events: none;
    opacity: 0;
  }

  .jumpscare__shadow--left {
    left: 0;
    transform: translateX(-110vw);
    transition: transform 0.55s ease-in, opacity 0.2s;
  }

  .jumpscare__shadow--right {
    right: 0;
    transform: translateX(110vw) scaleX(-1);
    transition: transform 0.55s ease-in, opacity 0.2s;
  }

  .jumpscare__shadow--active {
    opacity: 1;
  }

  .jumpscare__shadow--left.jumpscare__shadow--active {
    transform: translateX(110vw);
  }

  .jumpscare__shadow--right.jumpscare__shadow--active {
    transform: translateX(-110vw) scaleX(-1);
  }

  .jumpscare__shadow-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0 25px rgba(139,0,0,0.9)) contrast(1.6);
  }

  .jumpscare__image {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    z-index: 4;
    pointer-events: none;
    transition: opacity 0.15s;
    background: #000;
    padding: 1rem 1rem 2rem;
    box-sizing: border-box;
    overflow: hidden;
  }

  .jumpscare__image--visible {
    opacity: 1;
  }

  .jumpscare__stage {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-height: 100%;
    gap: 0.85rem;
  }

  .jumpscare--spotlight .jumpscare__vignette {
    opacity: 0.2;
    background: radial-gradient(ellipse at center, transparent 35%, rgba(0,0,0,0.5) 100%);
  }

  .jumpscare__image--spotlight .jumpscare__vignette {
    opacity: 0.2;
  }

  .jumpscare__face-glow {
    position: absolute;
    width: min(70vw, 420px);
    height: min(70vw, 420px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180,20,20,0.35) 0%, rgba(80,0,0,0.15) 45%, transparent 72%);
    animation: faceGlowPulse 0.5s ease-in-out infinite alternate;
    z-index: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    pointer-events: none;
  }

  @keyframes faceGlowPulse {
    to { transform: translate(-50%, -55%) scale(1.08); opacity: 0.9; }
  }

  .jumpscare__face-wrap {
    position: relative;
    z-index: 1;
    flex: 0 1 auto;
    max-height: min(58vh, 480px);
    animation: faceLunge 0.6s cubic-bezier(0.2, 1.8, 0.4, 1) forwards;
  }

  @keyframes faceLunge {
    0% { transform: scale(0.25) translateY(80px); opacity: 0; }
    55% { transform: scale(1.12) translateY(-8px); opacity: 1; }
    100% { transform: scale(1.02) translateY(0); opacity: 1; }
  }

  .jumpscare__image--glitch .jumpscare__face-wrap {
    animation: faceLunge 0.6s cubic-bezier(0.2, 1.8, 0.4, 1) forwards, faceGlitchWrap 0.12s steps(3) 0.6s infinite;
  }

  @keyframes faceGlitchWrap {
    0%, 100% { transform: scale(1.02) translate(0); }
    33% { transform: scale(1.03) translate(-6px, 2px); }
    66% { transform: scale(1.01) translate(5px, -3px); }
  }

  .jumpscare__face {
    display: block;
    width: min(78vw, 420px);
    height: auto;
    max-height: min(58vh, 480px);
    object-fit: contain;
    margin: 0 auto;
    filter: brightness(1.08) contrast(1.35) saturate(0.95) drop-shadow(0 0 40px rgba(180,0,0,0.75));
    animation: faceBreath 0.35s ease-in-out infinite alternate;
  }

  .jumpscare__face-wrap--photo .jumpscare__face {
    width: min(82vw, 460px);
    max-height: min(58vh, 480px);
    filter: brightness(1.05) contrast(1.4) saturate(0.9) drop-shadow(0 0 55px rgba(120,0,0,0.8));
  }

  @keyframes faceBreath {
    to { transform: scale(1.02); }
  }

  .jumpscare__image--glitch .jumpscare__face {
    animation: faceBreath 0.35s ease-in-out infinite alternate, faceColorGlitch 0.15s steps(2) infinite;
  }

  @keyframes faceColorGlitch {
    0% { filter: brightness(1.05) contrast(1.4) saturate(0.9) hue-rotate(0deg) drop-shadow(0 0 55px rgba(120,0,0,0.8)); }
    50% { filter: brightness(1.15) contrast(1.55) saturate(0.85) hue-rotate(-5deg) drop-shadow(0 0 70px rgba(200,0,0,0.95)); }
    100% { filter: brightness(1.02) contrast(1.38) saturate(0.88) hue-rotate(3deg) drop-shadow(0 0 48px rgba(100,0,0,0.75)); }
  }

  .jumpscare__face-eyes {
    display: none;
  }

  .jumpscare__scream {
    position: relative;
    z-index: 5;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 3.5vw, 1.55rem);
    font-weight: 700;
    color: #ff3b3b;
    letter-spacing: 0.12em;
    margin: 0;
    padding: 0.65rem 1rem;
    max-width: min(92vw, 540px);
    text-align: center;
    line-height: 1.4;
    opacity: 0;
    background: rgba(0, 0, 0, 0.72);
    border: 1px solid rgba(255, 60, 60, 0.45);
    text-shadow: 0 2px 0 #000, 0 0 12px rgba(255,0,0,0.6);
    animation: screamIn 0.35s ease 0.15s forwards;
  }

  .jumpscare__image--visible .jumpscare__scream {
    opacity: 1;
  }

  .jumpscare__quick-book {
    position: relative;
    z-index: 7;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .65rem;
    min-height: 48px;
    margin-top: .15rem;
    padding: .8rem 1.35rem;
    border: 1px solid #ff554c;
    color: #fff;
    background: #a91f19;
    box-shadow: 0 0 28px rgba(210,35,28,.5);
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-decoration: none;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: auto;
  }

  .jumpscare__image--visible .jumpscare__quick-book {
    animation: quickBookIn .3s ease 1s forwards;
  }

  @keyframes quickBookIn {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes screamIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .jumpscare--booking .jumpscare__face-wrap,
  .jumpscare--scroll .jumpscare__face-wrap {
    animation: faceLungeVisible 0.45s cubic-bezier(0.15, 1.5, 0.35, 1) forwards;
  }

  @keyframes faceLungeVisible {
    0% { transform: scale(0.2) translateY(60px); opacity: 0; }
    55% { transform: scale(1.1) translateY(-8px); opacity: 1; }
    100% { transform: scale(1.02) translateY(0); opacity: 1; }
  }

  .jumpscare--booking .jumpscare__scream,
  .jumpscare--scroll .jumpscare__scream {
    font-size: clamp(1rem, 3.4vw, 1.5rem);
    letter-spacing: 0.08em;
    max-width: min(92vw, 560px);
    animation: screamInVisible 0.3s ease 0.1s forwards;
  }

  @keyframes screamInVisible {
    from { opacity: 0; transform: translateY(10px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .jumpscare--booking.jumpscare--shake,
  .jumpscare--scroll.jumpscare--shake {
    animation: scareShake 0.1s linear infinite;
  }

  @media (max-height: 700px) {
    .jumpscare__face,
    .jumpscare__face-wrap--photo .jumpscare__face,
    .jumpscare__face-wrap {
      max-height: min(48vh, 360px);
    }
    .jumpscare__face {
      width: min(70vw, 340px);
    }
    .jumpscare__scream {
      font-size: clamp(0.95rem, 3vw, 1.25rem);
      padding: 0.5rem 0.85rem;
    }
  }

  .jumpscare__cta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    z-index: 6;
    background: rgba(0, 0, 0, 0.88);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
  }

  .jumpscare__cta[hidden] {
    display: none !important;
  }

  .jumpscare__cta--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .jumpscare__cta-eyebrow {
    font-size: 0.8rem;
    color: #c2bbb5;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .jumpscare__cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.8rem);
    color: #ff3333;
    letter-spacing: 0.1em;
    text-shadow: 0 0 30px rgba(255,0,0,0.5);
    margin-bottom: 1rem;
  }

  .jumpscare__cta-sub {
    color: #ddd6d0;
    font-size: 0.95rem;
    max-width: 400px;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .jumpscare__cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .jumpscare__cta-btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: linear-gradient(135deg, #c00000, #8b0000);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.12em;
    font-size: 0.9rem;
    border: 1px solid rgba(255,80,80,0.4);
    box-shadow: 0 0 30px rgba(139,0,0,0.6);
    transition: transform 0.2s, box-shadow 0.2s;
    animation: ctaPulseScare 2s ease-in-out infinite;
  }

  @keyframes ctaPulseScare {
    0%, 100% { box-shadow: 0 0 30px rgba(139,0,0,0.6); }
    50% { box-shadow: 0 0 50px rgba(255,50,50,0.9); }
  }

  .jumpscare__cta-btn:hover {
    transform: scale(1.05);
  }

  .jumpscare__cta-btn--ghost {
    background: transparent;
    border: 1px solid #555;
    box-shadow: none;
    animation: none;
    color: #ccc;
  }

  .jumpscare__dismiss {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0,0,0,0.8);
    border: 1px solid #555;
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .jumpscare--active .jumpscare__dismiss { opacity: 1; }

  body.reduced-motion-active .jumpscare { display: none !important; }

  @media (max-width: 768px) {
    .jumpscare__shadow { width: 200px; height: 280px; }
    .jumpscare__cta-actions { flex-direction: column; width: 100%; max-width: 280px; }
    .jumpscare__cta-btn { width: 100%; text-align: center; }
  }
</style>
