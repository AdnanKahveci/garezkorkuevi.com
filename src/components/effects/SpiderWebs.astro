---
// SpiderWebs - Dekoratif örümcek ağları
interface Props {
  position?: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
}
const { position = 'top-left' } = Astro.props;
---

<div class={`spider-web spider-web--${position}`} aria-hidden="true">
  <svg class="spider-web__svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
    <g class="spider-web__strands">
      <line x1="0" y1="0" x2="200" y2="200" stroke="rgba(220,220,220,0.28)" stroke-width="0.7"/>
      <line x1="0" y1="0" x2="200" y2="100" stroke="rgba(220,220,220,0.22)" stroke-width="0.5"/>
      <line x1="0" y1="0" x2="100" y2="200" stroke="rgba(220,220,220,0.22)" stroke-width="0.5"/>
      <line x1="0" y1="0" x2="200" y2="50" stroke="rgba(220,220,220,0.18)" stroke-width="0.4"/>
      <line x1="0" y1="0" x2="50" y2="200" stroke="rgba(220,220,220,0.18)" stroke-width="0.4"/>
      <path d="M0,0 Q100,60 200,120" fill="none" stroke="rgba(220,220,220,0.16)" stroke-width="0.4"/>
      <path d="M0,0 Q60,100 120,200" fill="none" stroke="rgba(220,220,220,0.16)" stroke-width="0.4"/>
      <path d="M0,0 Q80,30 160,60" fill="none" stroke="rgba(220,220,220,0.12)" stroke-width="0.3"/>
      <path d="M0,0 Q30,80 60,160" fill="none" stroke="rgba(220,220,220,0.12)" stroke-width="0.3"/>
      <circle cx="60" cy="60" r="2.5" fill="rgba(200,200,200,0.2)"/>
    </g>
  </svg>
  <slot />
</div>

<style>
  .spider-web {
    position: absolute;
    width: 320px;
    height: 320px;
    pointer-events: none;
    z-index: 7;
    opacity: 1;
  }
  .spider-web--top-left { top: 0; left: 0; }
  .spider-web--top-right { top: 0; right: 0; transform: scaleX(-1); }
  .spider-web--bottom-left { bottom: 0; left: 0; transform: scaleY(-1); }
  .spider-web--bottom-right { bottom: 0; right: 0; transform: scale(-1); }
  .spider-web__svg {
    width: 100%;
    height: 100%;
    animation: webSway 6s ease-in-out infinite alternate;
  }
  .spider-web__strands {
    transform-origin: 0 0;
    animation: webSwayInner 4s ease-in-out infinite alternate-reverse;
  }
  @keyframes webSway {
    to { transform: rotate(2deg); }
  }
  @keyframes webSwayInner {
    to { transform: rotate(-1.5deg); }
  }
  @media (max-width: 768px) {
    .spider-web { width: 100px; height: 100px; opacity: 0.4; }
    .spider-web--bottom-left,
    .spider-web--bottom-right { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .spider-web__svg, .spider-web__strands { animation: none; }
  }
</style>
